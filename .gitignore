# ============================================================
#  MAIA – Root .gitignore
# ============================================================

# ------------------------------------------------------------
# Node / Next.js
# ------------------------------------------------------------
node_modules/
.next/
.nuxt/
.cache/
dist/
build/
out/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
.yarn/

# ------------------------------------------------------------
# Python virtual environments & caches
# ------------------------------------------------------------
venv/
.venv/
env/
.env/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/
*.egg
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml
*.cover

# ------------------------------------------------------------
# Whisper / ML model files  (the biggest space-savers!)
# ------------------------------------------------------------
*.bin
*.pt
*.pth
*.ckpt
*.safetensors
*.gguf
*.ggml
services/whisperCpp/models/
services/transcriber/models/

# ------------------------------------------------------------
# Compiled binaries & build artifacts (whisperCpp/Release)
# ------------------------------------------------------------
services/whisperCpp/Release/
*.exe
*.dll
*.so
*.dylib
*.obj
*.o
*.lib
*.a
*.pdb
*.ilk
*.exp

# ------------------------------------------------------------
# Audio / media scratch files
# ------------------------------------------------------------
services/whisperCpp/audio/
sample_voices/
results/
*.wav
*.mp3
*.mp4
*.ogg
*.flac
*.webm

# ------------------------------------------------------------
# SSL certificates & secrets
# ------------------------------------------------------------
cert/
*.pem
*.key
*.crt
*.p12
*.pfx
.env
.env.*
!.env.example
!.env.sample
secrets/

# ------------------------------------------------------------
# Jupyter notebooks checkpoints
# ------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
logs/
*.log
*.log.*

# ------------------------------------------------------------
# OS / editor junk
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------
# Misc generated files
# ------------------------------------------------------------
FileList.csv
*.tmp
*.bak
*.orig